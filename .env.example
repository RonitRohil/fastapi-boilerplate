# App
APP_NAME="FastAPI Boilerplate"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://fastapi_user:your_password@localhost:5432/fastapi_boilerplate

# JWT
SECRET_KEY=your-super-secret-key-minimum-32-chars-long-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# First Admin User (seeded on startup)
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=Admin@1234